@@ -248,3 +248,170 @@ html {
 .animate-slide-out-left {
   animation: slide-out-left 0.3s ease-in forwards;
 }
+
+/* =============================================
+   PREMIUM UPGRADES
+   ============================================= */
+
+/* Gold shimmer effect */
+@keyframes gold-shimmer {
+  0% { background-position: -200% center; }
+  100% { background-position: 200% center; }
+}
+
+.gold-shimmer {
+  background: linear-gradient(
+    90deg,
+    #c9a84c 0%,
+    #e8c96a 40%,
+    #f5e08a 50%,
+    #e8c96a 60%,
+    #c9a84c 100%
+  );
+  background-size: 200% auto;
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+  background-clip: text;
+  animation: gold-shimmer 4s linear infinite;
+}
+
+/* Floating animation */
+@keyframes float-gentle {
+  0%, 100% { transform: translateY(0px); }
+  50% { transform: translateY(-6px); }
+}
+
+.animate-float {
+  animation: float-gentle 4s ease-in-out infinite;
+}
+
+/* Premium card hover */
+.premium-card {
+  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
+  will-change: transform;
+}
+
+.premium-card:hover {
+  transform: translateY(-4px);
+  box-shadow: 0 20px 60px -10px rgba(201, 168, 76, 0.2), 0 8px 24px -8px rgba(0,0,0,0.12);
+}
+
+/* Glass morphism effect */
+.glass {
+  background: rgba(255, 255, 255, 0.7);
+  backdrop-filter: blur(12px);
+  -webkit-backdrop-filter: blur(12px);
+  border: 1px solid rgba(255, 255, 255, 0.5);
+}
+
+/* Glow ring for the instructor photo */
+@keyframes glow-ring {
+  0%, 100% { box-shadow: 0 0 0 4px rgba(201, 168, 76, 0.4), 0 0 30px rgba(201, 168, 76, 0.2); }
+  50% { box-shadow: 0 0 0 8px rgba(201, 168, 76, 0.15), 0 0 50px rgba(201, 168, 76, 0.3); }
+}
+
+.animate-glow-ring {
+  animation: glow-ring 3s ease-in-out infinite;
+}
+
+/* Gradient border for popular card */
+.pricing-popular {
+  box-shadow: 0 0 0 2px #c9a84c, 0 20px 60px -10px rgba(201, 168, 76, 0.3), 0 8px 24px rgba(0,0,0,0.1);
+}
+
+/* Problem card hover */
+.problem-card {
+  transition: border-color 0.3s ease, background-color 0.3s ease, transform 0.2s ease;
+}
+
+.problem-card:hover {
+  transform: translateX(6px);
+  border-color: #b85c38 !important;
+}
+
+/* Dotted pattern background */
+.dot-pattern {
+  background-image: radial-gradient(circle, rgba(201, 168, 76, 0.15) 1px, transparent 1px);
+  background-size: 24px 24px;
+}
+
+/* Mesh gradient background */
+.mesh-gradient {
+  background: 
+    radial-gradient(at 40% 20%, rgba(201, 168, 76, 0.1) 0px, transparent 50%),
+    radial-gradient(at 80% 0%, rgba(184, 92, 56, 0.08) 0px, transparent 40%),
+    radial-gradient(at 0% 50%, rgba(201, 168, 76, 0.06) 0px, transparent 40%);
+}
+
+/* Btn shine sweep */
+.btn-shine {
+  position: relative;
+  overflow: hidden;
+}
+
+.btn-shine::after {
+  content: '';
+  position: absolute;
+  top: -50%;
+  left: -60%;
+  width: 35%;
+  height: 200%;
+  background: rgba(255, 255, 255, 0.25);
+  transform: skewX(-20deg);
+  transition: left 0.5s ease;
+}
+
+.btn-shine:hover::after {
+  left: 120%;
+}
+
+/* Selection color */
+::selection {
+  background: rgba(201, 168, 76, 0.25);
+  color: #0e0c0a;
+}
+
+/* Testimonial quote */
+.quote-mark-bg {
+  font-family: var(--font-cormorant), Georgia, serif;
+  font-size: 9rem;
+  line-height: 0.6;
+  color: rgba(201, 168, 76, 0.1);
+  user-select: none;
+  pointer-events: none;
+}
+
+/* Animated underline */
+.hover-underline {
+  position: relative;
+}
+
+.hover-underline::after {
+  content: '';
+  position: absolute;
+  bottom: -2px;
+  left: 0;
+  width: 0;
+  height: 1.5px;
+  background: #c9a84c;
+  transition: width 0.3s ease;
+}
+
+.hover-underline:hover::after {
+  width: 100%;
+}
+
+/* Stat number styling */
+.stat-number {
+  font-variant-numeric: tabular-nums;
+}
+
+/* Guarantee seal spin */
+@keyframes slow-spin {
+  from { transform: rotate(0deg); }
+  to { transform: rotate(360deg); }
+}
+
+.seal-spin {
+  animation: slow-spin 20s linear infinite;
+}
